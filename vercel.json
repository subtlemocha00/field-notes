{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/__/auth/:path*",
      "destination": "https://field-book-cfba0.firebaseapp.com/__/auth/:path*"
    },
    {
      "source": "/__/firebase/:path*",
      "destination": "https://field-book-cfba0.firebaseapp.com/__/firebase/:path*"
    },
    { "source": "/((?!.*\\.).*)", "destination": "/index.html" }
  ]
}
